# URL base da API (sempre com /api/v1). O Vite le no build — em producao defina no painel (Buildtime).
#
# Docker Compose (frontend no host): http://localhost:3001/api/v1
# Producao (exemplo): https://api-luxuosa.jwsoftware.com.br/api/v1
VITE_API_URL=http://localhost:3001/api/v1

# Opcional em producao: porta do `vite preview` / npm start (Coolify costuma expor 3000)
# PORT=3000
